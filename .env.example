# B-BOT 환경 변수 예시
# 사용법: cp .env.example .env 후 값 채우기 (실제 값은 절대 커밋 금지)
# 분류: [필수] 없으면 부팅 실패 / [선택] 해당 기능만 비활성

# ── Slack ────────────────────────────────────────────────
# [필수] Bot User OAuth Token (xoxb-...)
#   Slack App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=
# [선택·권장] 요청 서명 검증용 Signing Secret
#   Slack App → Basic Information → App Credentials → Signing Secret
#   ※ 현재 코드는 아직 검증에 미사용(보안 TODO). HTTP 웹훅 보안을 위해 채워둘 것
SLACK_BOT_SIGNING_SECRET=

# ── Database (멤버 등) ───────────────────────────────────
# [필수] 인프라 담당에게 요청 (현재: 라즈베리파이 도커 bcsd-mysql / 추후 Postgres)
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# ── Google (Meet 생성·OAuth) ─────────────────────────────
# [선택] Google Cloud Console → API 및 서비스 → 사용자 인증 정보(OAuth 클라이언트)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# [선택] GCP 프로젝트 ID (Meet 연동)
GOOGLE_PROJECT_ID=

# ── 기타 기능 ────────────────────────────────────────────
# [선택] 봇 정적 파일 공개 베이스 URL (끝에 / 포함). 예: https://bot.example.com/
#   services/slack/message.ts 에서 회칙 PDF 링크에 사용
APP_BASE_URL=
# [선택] Clarity 에러 크롤 태스크용 토큰 (tasks/crawl/clarity.ts)
CLARITY_TOKEN=
# [선택] Clarity 에러 알림에 표기할 관리자 이름
ADMIN_NAME=

# ── 로컬 모델(RAG, Ollama 사이드카) ──────────────────────
# [선택] 기본 http://localhost:11434 (봇과 같은 박스의 Ollama). 보통 비워둠
OLLAMA_BASE_URL=
# [선택] 생성 모델 (기본 qwen2.5:3b)
OLLAMA_GEN_MODEL=
